<!DOCTYPE html>
<html>
<head>
  <title>Job Posting Creator</title>
  <style>
    body {
      font-family: Arial;
      padding: 20px;
    }

    input, textarea {
      width: 300px;
      padding: 8px;
      margin-bottom: 10px;
    }

    button {
      padding: 8px 15px;
      cursor: pointer;
    }

    #output {
      margin-top: 20px;
      background: #f2f2f2;
      padding: 10px;
      width: 320px;
    }
  </style>
</head>
<body>

  <h2>Create Job Posting</h2>

  <input type="text" id="jobTitle" placeholder="Job Title"><br>
  <input type="text" id="company" placeholder="Company Name"><br>
  <textarea id="description" placeholder="Job Description"></textarea><br>

  <button onclick="createJob()">Create Job Post</button>

  <div id="output"></div>

  <script>
    function createJob() {
      const title = document.getElementById("jobTitle").value;
      const company = document.getElementById("company").value;
      const desc = document.getElementById("description").value;

      if (!title || !company || !desc) {
        alert("Please fill all fields!");
        return;
      }

      const output = `
        <h3>Job Posted</h3>
        <p><strong>Title:</strong> ${title}</p>
        <p><strong>Company:</strong> ${company}</p>
        <p><strong>Description:</strong> ${desc}</p>
      `;

      document.getElementById("output").innerHTML = output;
    }
  </script>

</body>
</html>
